# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1  # Optional: custom API endpoint

# Azure OpenAI Configuration (if using Azure)
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=your-embedding-deployment

# Ollama Configuration (if using local models)
# OLLAMA_BASE_URL=http://localhost:11434

# DashScope Configuration (Alibaba Cloud)
# For DashScope OpenAI-compatible embedding, use your DashScope key
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DeepSeek Configuration (if using DeepSeek)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_API_BASE=https://api.deepseek.com

# Application Settings
LOG_LEVEL=INFO
TRACE_ENABLED=true

# Database Settings
CHROMA_PERSIST_DIR=data/db/chroma
BM25_INDEX_DIR=data/db/bm25

# Optional: Hugging Face Token (for some models)
# HUGGINGFACE_TOKEN=your_hf_token_here
